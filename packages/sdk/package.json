{
  "name": "hyperflow-sdk",
  "version": "0.1.0",
  "description": "SDK TypeScript para los agentes de HyperFlow (via MCP Streamable HTTP)",
  "license": "MIT",
  "author": "mcortezv",
  "homepage": "https://github.com/hyperlabs-ai/hyperflow-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hyperlabs-ai/hyperflow-sdk.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/hyperlabs-ai/hyperflow-sdk/issues"
  },
  "keywords": ["hyperflow", "mcp", "ai-agents", "sdk", "model-context-protocol", "russell"],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "typescript": "~5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
